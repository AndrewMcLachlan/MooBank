<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <SpaRoot>..\MooBank.Web.App</SpaRoot>
    <SpaProxyLaunchCommand>npm start</SpaProxyLaunchCommand>
    <SpaProxyServerUrl>https://localhost:3005</SpaProxyServerUrl>
    <DefaultItemExcludes>$(DefaultItemExcludes);$(SpaRoot)node_modules\**</DefaultItemExcludes>
    <UserSecretsId>6fe8aeec-2ada-4d1b-bfd6-2bcfbbf5f7d9</UserSecretsId>
    <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
    <DockerfileContext>..\..</DockerfileContext>
    <InterceptorsNamespaces>$(InterceptorsNamespaces);Microsoft.AspNetCore.OpenApi.Generated</InterceptorsNamespaces>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Asm.AspNetCore.Api" />
    <PackageReference Include="Asm.ModelContextProtocol" />
    <PackageReference Include="Azure.Monitor.OpenTelemetry.AspNetCore" />
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" />
    <PackageReference Include="Microsoft.AspNetCore.SpaProxy">
      <TreatAsUsed>true</TreatAsUsed>
    </PackageReference>
    <PackageReference Include="Microsoft.Azure.WebJobs.Extensions" />
    <PackageReference Include="Microsoft.Build">
      <TreatAsUsed>true</TreatAsUsed>
    </PackageReference>
    <PackageReference Include="Microsoft.Extensions.ApiDescription.Server">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.Extensions.Diagnostics.HealthChecks.EntityFrameworkCore" />
    <PackageReference Include="ModelContextProtocol.AspNetCore" />
    <PackageReference Include="Swashbuckle.AspNetCore.SwaggerUI" />
  </ItemGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <OpenApiGenerateDocuments>true</OpenApiGenerateDocuments>
    <OpenApiDocumentsDirectory>.</OpenApiDocumentsDirectory>
    <OpenApiGenerateDocumentsOptions>--file-name openapi-v1</OpenApiGenerateDocumentsOptions>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\MooBank.Abs\MooBank.Abs.csproj" />
    <ProjectReference Include="..\MooBank\MooBank.csproj" />
    <ProjectReference Include="..\MooBank.Domain\MooBank.Domain.csproj" />
    <ProjectReference Include="..\MooBank.Infrastructure\MooBank.Infrastructure.csproj" />
    <ProjectReference Include="..\MooBank.Institution.Ing\MooBank.Institution.Ing.csproj" />
    <ProjectReference Include="..\MooBank.Institution.AustralianSuper\MooBank.Institution.AustralianSuper.csproj" />
    <ProjectReference Include="..\MooBank.Institution.Macquarie\MooBank.Institution.Macquarie.csproj" />
    <ProjectReference Include="..\MooBank.Models\MooBank.Models.csproj" />
    <ProjectReference Include="..\MooBank.Modules.Accounts\MooBank.Modules.Accounts.csproj" />
    <ProjectReference Include="..\MooBank.Modules.Assets\MooBank.Modules.Assets.csproj" />
    <ProjectReference Include="..\MooBank.Modules.Bills\MooBank.Modules.Bills.csproj" />
    <ProjectReference Include="..\MooBank.Modules.Budgets\MooBank.Modules.Budgets.csproj" />
    <ProjectReference Include="..\MooBank.Modules.Families\MooBank.Modules.Families.csproj" />
    <ProjectReference Include="..\MooBank.Modules.Forecast\MooBank.Modules.Forecast.csproj" />
    <ProjectReference Include="..\MooBank.Modules.Groups\MooBank.Modules.Groups.csproj" />
    <ProjectReference Include="..\MooBank.Modules.Institutions\MooBank.Modules.Institutions.csproj" />
    <ProjectReference Include="..\MooBank.Modules.Instruments\MooBank.Modules.Instruments.csproj" />
    <ProjectReference Include="..\MooBank.Modules.ReferenceData\MooBank.Modules.ReferenceData.csproj" />
    <ProjectReference Include="..\MooBank.Modules.Reports\MooBank.Modules.Reports.csproj" />
    <ProjectReference Include="..\MooBank.Modules.Stocks\MooBank.Modules.Stocks.csproj" />
    <ProjectReference Include="..\MooBank.Modules.Tags\MooBank.Modules.Tags.csproj" />
    <ProjectReference Include="..\MooBank.Modules.Transactions\MooBank.Modules.Transactions.csproj" />
